# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/adguardhome-sync).
DATA_ROOT=/mnt/user/appdata/adguardhome-sync

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Set a custom config file.
CONFIGFILE=/config/adguardhome-sync.yaml
