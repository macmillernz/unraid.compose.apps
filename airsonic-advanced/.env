# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/airsonic-advanced).
DATA_ROOT=/mnt/user/appdata/airsonic-advanced
# Location of music.
MUSIC_ROOT=/mnt/user/appdata/airsonic-advanced/music
# Location for playlists to be saved to.
PLAYLISTS_ROOT=/mnt/user/appdata/airsonic-advanced/playlists
# Location of podcasts.
PODCASTS_ROOT=/mnt/user/appdata/airsonic-advanced/podcasts

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# For setting url-base in reverse proxy setups.
CONTEXT_PATH=
# For passing additional java options.
JAVA_OPTS=
