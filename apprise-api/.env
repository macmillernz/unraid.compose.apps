# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/apprise-api).
DATA_ROOT=/mnt/user/appdata/apprise-api

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Max attachment size in Mb. `0` disables attachments. Must have `/attachments` mounted to set to a positive value.
APPRISE_ATTACH_SIZE=0
