# Fill in every value below before starting this stack - the compose
# file requires PG_PASS and AUTHENTIK_SECRET_KEY, it won't start without them.

# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/authentik).
DATA_ROOT=/mnt/user/appdata/authentik

# Postgres
PG_DB=authentik
PG_USER=authentik
# To generate, run "openssl rand -base64 32" from the terminal.
PG_PASS=changeme-generate-a-strong-password

# To generate, run "openssl rand -base64 32" from the terminal.
AUTHENTIK_SECRET_KEY=changeme-generate-a-random-secret

AUTHENTIK_IMAGE=ghcr.io/goauthentik/server
AUTHENTIK_TAG=2026.5.4
COMPOSE_PORT_HTTP=9000
COMPOSE_PORT_HTTPS=9443

# --- Only needed if you're using the bundled certbot service (Let's
# Encrypt via Cloudflare DNS-01) - delete these two lines and the
# certbot service in docker-compose.yml if you don't need it.
DOMAIN=example.com
LETSENCRYPT_EMAIL=you@example.com
