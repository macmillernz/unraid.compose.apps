# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/bambustudio).
DATA_ROOT=/mnt/user/appdata/bambustudio

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Set this to true to enable dark mode for Bambu Studio.
DARK_MODE=true
