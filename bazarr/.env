# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/bazarr).
DATA_ROOT=/mnt/user/appdata/bazarr

# These should point at the exact same paths Radarr/Sonarr use, so Bazarr
# can find the same files to attach subtitles to.
MOVIES_ROOT=/mnt/user/data/media/movies
TV_ROOT=/mnt/user/data/media/tv

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
