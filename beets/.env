# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/beets).
DATA_ROOT=/mnt/user/appdata/beets
# Music library
MUSIC_ROOT=/mnt/user/appdata/beets/music
# Non processed music
DOWNLOADS_ROOT=/mnt/user/appdata/beets/downloads

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
