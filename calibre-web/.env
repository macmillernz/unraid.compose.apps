# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/calibre-web).
DATA_ROOT=/mnt/user/appdata/calibre-web

# Your existing Calibre library folder (the one containing metadata.db).
BOOKS_ROOT=/mnt/user/data/media/books

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
