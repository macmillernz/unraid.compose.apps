# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/calibre).
DATA_ROOT=/mnt/user/appdata/calibre

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Optionally set a password for the gui.
# To generate, run "openssl rand -base64 32" from the terminal.
PASSWORD=changeme-generate-a-strong-secret
# Optionally pass cli start arguments to calibre.
CLI_ARGS=
