# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/changedetection.io).
DATA_ROOT=/mnt/user/appdata/changedetection.io

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Specify the full URL (including protocol) when running behind a reverse proxy
BASE_URL=
# Specify the full URL to your chrome driver instance. See the [wiki](https://github.com/dgtlmoon/changedetection.io/wiki/Playwright-content-fetcher) for details.
PLAYWRIGHT_DRIVER_URL=
