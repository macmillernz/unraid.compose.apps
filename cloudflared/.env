# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/cloudflared).
DATA_ROOT=/mnt/user/appdata/cloudflared

# Tunnel token from the Cloudflare Zero Trust dashboard: Networks > Tunnels >
# create a tunnel > choose "Docker" as the connector > copy the token from
# the install command shown there (the long string after --token).
TUNNEL_TOKEN=
