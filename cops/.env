# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/cops).
DATA_ROOT=/mnt/user/appdata/cops
# Calibre metadata.db location.
BOOKS_ROOT=/mnt/user/appdata/cops/books

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
