# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/davos).
DATA_ROOT=/mnt/user/appdata/davos
# davos's file download location
DOWNLOAD_ROOT=/mnt/user/appdata/davos/download

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
