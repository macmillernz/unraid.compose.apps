# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/diskover).
DATA_ROOT=/mnt/user/appdata/diskover
# Default mount point to crawl
DATA_DIR_ROOT=/mnt/user/appdata/diskover/data

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
