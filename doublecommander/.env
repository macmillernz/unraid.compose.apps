# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/doublecommander).
DATA_ROOT=/mnt/user/appdata/doublecommander
# Host data directories, mount as many as needed.
DATA_DIR_ROOT=/mnt/user/appdata/doublecommander/data

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
