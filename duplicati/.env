# Fill in every value below before starting this stack - the compose
# file requires SETTINGS_ENCRYPTION_KEY and DUPLICATI__WEBSERVICE_PASSWORD,
# it won't start without them.

# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/duplicati).
DATA_ROOT=/mnt/user/appdata/duplicati

# Where local backup destinations are written (if you're backing up to
# a remote/cloud destination instead, this can just be left as-is).
BACKUPS_ROOT=/mnt/user/backups/duplicati

# The actual files/shares you want backed up.
SOURCE_ROOT=/mnt/user/data

# Encrypts Duplicati's own configuration database - minimum 8 characters.
# To generate, run "openssl rand -base64 32" from the terminal.
SETTINGS_ENCRYPTION_KEY=changeme-generate-a-random-secret

# Password for the Duplicati web UI login.
# To generate, run "openssl rand -base64 32" from the terminal.
DUPLICATI__WEBSERVICE_PASSWORD=changeme-generate-a-strong-password
