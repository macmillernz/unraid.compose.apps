# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/emby).
DATA_ROOT=/mnt/user/appdata/emby
# Media goes here. Add as many as needed e.g. `/data/movies`, `/data/tv`, etc.
DATA_TVSHOWS_ROOT=/mnt/user/appdata/emby/data/tvshows
# Media goes here. Add as many as needed e.g. `/data/movies`, `/data/tv`, etc.
DATA_MOVIES_ROOT=/mnt/user/appdata/emby/data/movies

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
