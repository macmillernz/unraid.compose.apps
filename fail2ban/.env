# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/fail2ban).
DATA_ROOT=/mnt/user/appdata/fail2ban
# Host logs. Mounted as Read Only.
VAR_LOG_ROOT=/mnt/user/appdata/fail2ban/var/log

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Set the container log verbosity. Valid options are -v, -vv, -vvv, -vvvv, or leaving the value blank or not setting the variable.
VERBOSITY=-vv
