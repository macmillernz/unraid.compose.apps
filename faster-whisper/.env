# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/faster-whisper).
DATA_ROOT=/mnt/user/appdata/faster-whisper

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# If set to `true`, or any other value, the container will output debug logs.
DEBUG=
# If set to `true`, or any other value, the container will not attempt to download models from HuggingFace and will only use locally-provided models.
LOCAL_ONLY=
# Number of candidates to consider simultaneously during transcription.
WHISPER_BEAM=1
# Two character code for the language that you will speak to the add-on.
WHISPER_LANG=auto
# Whisper model that will be used for transcription. From [here](https://github.com/SYSTRAN/faster-whisper/blob/master/faster_whisper/utils.py#L11-L31).
WHISPER_MODEL=auto
