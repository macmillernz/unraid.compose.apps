# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/firefox).
DATA_ROOT=/mnt/user/appdata/firefox

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Specify one or multiple Firefox CLI flags, this string will be passed to the application in full.
FIREFOX_CLI=https://www.linuxserver.io/
