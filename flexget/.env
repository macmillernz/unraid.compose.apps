# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/flexget).
DATA_ROOT=/mnt/user/appdata/flexget

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Set the FlexGet webui password. Pay attention to Bash/YAML reserved characters.
# To generate, run "openssl rand -base64 32" from the terminal.
FG_WEBUI_PASSWORD=changeme-generate-a-strong-secret
