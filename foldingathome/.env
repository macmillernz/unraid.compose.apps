# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/foldingathome).
DATA_ROOT=/mnt/user/appdata/foldingathome

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Optionally pass additional cli arguments to `fah-client` on container start.
CLI_ARGS=
