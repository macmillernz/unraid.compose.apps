# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/heimdall).
DATA_ROOT=/mnt/user/appdata/heimdall

# Host ports - remapped from linuxserver.io's documented 80/443 defaults
# since those usually collide with something else already using port 80
# on an Unraid box.
HEIMDALL_HTTP_PORT=8080
HEIMDALL_HTTPS_PORT=8443

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
