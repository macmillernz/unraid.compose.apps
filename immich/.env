# See https://immich.app/docs/install/environment-variables for the full list.

# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/immich).
DATA_ROOT=/mnt/user/appdata/immich

# Pin a version, or leave as "release" for the latest stable release.
IMMICH_VERSION=release

# Where your photos/videos actually live.
UPLOAD_LOCATION=/mnt/user/appdata/immich/upload

# Database storage location.
DB_DATA_LOCATION=/mnt/user/appdata/immich/postgres

# Change these before first start - the compose file requires them.
# To generate, run "openssl rand -base64 32" from the terminal.
DB_PASSWORD=changeme-generate-a-strong-password
DB_USERNAME=postgres
DB_DATABASE_NAME=immich
