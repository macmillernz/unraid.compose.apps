# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/jackett).
DATA_ROOT=/mnt/user/appdata/jackett

# Jackett's "blackhole" folder for saved torrent files - point Sonarr/
# Radarr/etc. at the same path if you use blackhole mode instead of a
# direct download client integration.
DOWNLOADS_ROOT=/mnt/user/data/downloads/blackhole

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
