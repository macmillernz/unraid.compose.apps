# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/kasm).
OPT_ROOT=/mnt/user/appdata/kasm

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Optionally specify a DockerHub Username to pull private images.
DOCKER_HUB_USERNAME=USER
# Optionally specify a DockerHub password to pull private images.
# To generate, run "openssl rand -base64 32" from the terminal.
DOCKER_HUB_PASSWORD=changeme-generate-a-strong-secret
# Optionally specify the mtu options passed to dockerd.
DOCKER_MTU=1500
