# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/kimai).
DATA_ROOT=/mnt/user/appdata/kimai

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# If behind a reverse proxy set this to its IP or network CIDR so that Kimai trusts its headers.
TRUSTED_PROXIES=127.0.0.1/32
