# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/librewolf).
DATA_ROOT=/mnt/user/appdata/librewolf

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Specify one or multiple LibreWolf CLI flags, this string will be passed to the application in full.
LIBREWOLF_CLI=https://www.linuxserver.io/
