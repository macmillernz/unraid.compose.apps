# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/lidarr).
DATA_ROOT=/mnt/user/appdata/lidarr

# Where your music library actually lives.
MUSIC_ROOT=/mnt/user/data/media/music

# Where Lidarr picks up completed downloads from your download client.
DOWNLOADS_ROOT=/mnt/user/data/downloads

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
