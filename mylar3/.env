# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/mylar3).
DATA_ROOT=/mnt/user/appdata/mylar3
# Map to your comics folder.
COMICS_ROOT=/mnt/user/appdata/mylar3/comics
# Map to your downloads folder.
DOWNLOADS_ROOT=/mnt/user/appdata/mylar3/downloads

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
