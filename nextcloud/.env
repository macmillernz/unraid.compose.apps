# Fill in every value below before starting this stack - the compose
# file requires MYSQL_ROOT_PASSWORD and MYSQL_PASSWORD, it won't start
# without them. See https://github.com/nextcloud/docker#environment-variables
# for the full list of variables the image supports.

# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/nextcloud).
DATA_ROOT=/mnt/user/appdata/nextcloud

# Host port Nextcloud's web UI is published on.
NEXTCLOUD_PORT=8080

# Database
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
# To generate, run "openssl rand -base64 32" from the terminal.
MYSQL_PASSWORD=changeme-generate-a-strong-password
# To generate, run "openssl rand -base64 32" from the terminal.
MYSQL_ROOT_PASSWORD=changeme-generate-a-strong-password

# Setting both of these auto-creates the admin account and skips the
# web-based setup wizard entirely - only takes effect on first start.
NEXTCLOUD_ADMIN_USER=admin
# To generate, run "openssl rand -base64 32" from the terminal.
NEXTCLOUD_ADMIN_PASSWORD=changeme-generate-a-strong-password

# Nextcloud rejects requests to any hostname/IP not listed here (its
# "trusted domains" check) - add your Unraid box's IP and/or hostname,
# space-separated, or you'll be locked out of the web UI after setup.
NEXTCLOUD_TRUSTED_DOMAINS=
