# Fill in every value below before starting this stack - the compose
# file requires MYSQL_ROOT_PASSWORD and MYSQL_PASSWORD, it won't start
# without them. See https://github.com/nextcloud/docker#environment-variables
# for the full list of variables the image supports.

# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/nextcloud).
DATA_ROOT=/mnt/user/appdata/nextcloud

# Host port Nextcloud's web UI is published on.
NEXTCLOUD_PORT=8080

# Database
MYSQL_DATABASE=nextcloud
MYSQL_USER=nextcloud
# To generate, run "openssl rand -base64 32" from the terminal.
MYSQL_PASSWORD=changeme-generate-a-strong-password
# To generate, run "openssl rand -base64 32" from the terminal.
MYSQL_ROOT_PASSWORD=changeme-generate-a-strong-password

# Setting both of these auto-creates the admin account and skips the
# web-based setup wizard entirely - only takes effect on first start.
NEXTCLOUD_ADMIN_USER=admin
# To generate, run "openssl rand -base64 32" from the terminal.
NEXTCLOUD_ADMIN_PASSWORD=changeme-generate-a-strong-password

# Nextcloud rejects requests to any hostname/IP not listed here (its
# "trusted domains" check) - add your Unraid box's IP and/or hostname,
# space-separated, or you'll be locked out of the web UI after setup.
NEXTCLOUD_TRUSTED_DOMAINS=

# --- Reverse proxy support (only needed if Nextcloud sits behind
# another proxy - e.g. Authentik's proxy provider, Nginx Proxy Manager,
# Traefik, SWAG - leave all blank if accessed directly). See
# https://github.com/nextcloud/docker#reverse-proxy-considerations
#
# The exact external hostname your proxy exposes Nextcloud as (no
# protocol/port) - forces Nextcloud to treat every request as arriving at
# this host regardless of what Host header the proxy actually forwards.
# This is the standard fix for an HTTP 400 "Access through untrusted
# domain" error when using a reverse proxy - must also be listed in
# NEXTCLOUD_TRUSTED_DOMAINS above.
OVERWRITEHOST=
# http or https - set to https if your proxy terminates TLS in front of
# Nextcloud (leave blank otherwise).
OVERWRITEPROTOCOL=
# Full external URL, e.g. https://nextcloud.example.com - used for links
# generated by background/cron jobs, which have no request of their own
# to infer a host from.
OVERWRITECLIURL=
# Space-separated trusted proxy IPs/CIDRs - usually not needed if your
# proxy runs on the same Docker network (private IP ranges are already
# trusted by default), but set this if it connects from somewhere else.
TRUSTED_PROXIES=
