# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/obsidian).
DATA_ROOT=/mnt/user/appdata/obsidian

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# TEST VAR - added to exercise the catalog update-merge feature, not a
# real Obsidian setting. Safe to ignore/remove.
FAKE_TEST_VAR=hello-world
