# Fill in every value below marked "required" before starting this stack -
# the compose file won't start without them.

# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/openproject).
DATA_ROOT=/mnt/user/appdata/openproject

OPENPROJECT_TAG=17

# The hostname (or <server-ip>:8080) you'll use to access OpenProject -
# used to generate links/forms and email contexts.
OPENPROJECT_HOST__NAME=changeme-your-server-ip:8080

# Set to true if this is reachable over HTTPS (e.g. behind a reverse
# proxy terminating TLS). Leave false for plain HTTP.
OPENPROJECT_HTTPS=false

# Initial language for seed data and the default fallback for new users.
OPENPROJECT_DEFAULT__LANGUAGE=en

# Rails cryptographic key - must stay the same across restarts once set,
# or existing sessions/cookies will be invalidated. To generate, run
# "openssl rand -hex 64" from the terminal.
SECRET_KEY_BASE=changeme-generate-a-random-secret

# Default login on first run is admin/admin - change the password after
# your first login.
