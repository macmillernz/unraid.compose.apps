# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/openvscode-server).
DATA_ROOT=/mnt/user/appdata/openvscode-server

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Optional security token for accessing the Web UI (ie. `supersecrettoken`).
# To generate, run "openssl rand -base64 32" from the terminal.
CONNECTION_TOKEN=changeme-generate-a-strong-secret
# Optional path to a file inside the container that contains the security token for accessing the Web UI (ie. `/path/to/file`). Overrides `CONNECTION_TOKEN`.
# To generate, run "openssl rand -base64 32" from the terminal.
CONNECTION_SECRET=changeme-generate-a-strong-secret
# If this optional variable is set, user will have sudo access in the openvscode-server terminal with the specified password.
# To generate, run "openssl rand -base64 32" from the terminal.
SUDO_PASSWORD=changeme-generate-a-strong-secret
# Optionally set sudo password via hash (takes priority over `SUDO_PASSWORD` var). Format is `$type$salt$hashed`.
# To generate, run "openssl rand -base64 32" from the terminal.
SUDO_PASSWORD_HASH=changeme-generate-a-strong-secret
