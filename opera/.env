# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/opera).
DATA_ROOT=/mnt/user/appdata/opera

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Specify one or multiple Chromium CLI flags, this string will be passed to the application in full.
OPERA_CLI=https://www.linuxserver.io/
