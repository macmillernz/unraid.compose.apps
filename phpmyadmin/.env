# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/phpmyadmin).
DATA_ROOT=/mnt/user/appdata/phpmyadmin

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Set to `1` to allow you to connect to any server. Setting to `0` will only allow you to connect to specified hosts (See Application Setup)
PMA_ARBITRARY=1
# Set the URL you will use to access the web frontend
PMA_ABSOLUTE_URI=https://phpmyadmin.example.com
