# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/piwigo).
DATA_ROOT=/mnt/user/appdata/piwigo
# Image storage for Piwigo
GALLERY_ROOT=/mnt/user/appdata/piwigo/gallery

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
