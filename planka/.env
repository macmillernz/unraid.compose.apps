# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/planka).
DATA_ROOT=/mnt/user/appdata/planka

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# This sets the default language for sending notifications per user (if a user hasn't selected a language) and per board.
DEFAULT_LANGUAGE=en-US
