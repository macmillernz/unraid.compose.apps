# Fill in every value below marked "required" before starting this stack -
# the compose file won't start without them.

# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/planka).
DATA_ROOT=/mnt/user/appdata/planka

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# The URL you'll use to access Planka, including protocol and port
# (e.g. http://192.168.1.50:1337, or your reverse-proxied domain).
BASE_URL=changeme-http://your-server-ip:1337

# Postgres database (bundled as the "planka-db" service below - required,
# Planka has no built-in database of its own).
#
# DB_DATA_ROOT must NOT be inside DATA_ROOT (this is why it's a separate
# variable rather than "${DATA_ROOT}/db") - the planka service mounts the
# whole of DATA_ROOT and recursively fixes its ownership on every start,
# which would silently break the database if it lived in there too.
# Change the path below if your appdata root isn't /mnt/user/appdata.
DB_DATA_ROOT=/mnt/user/appdata/planka-db
PG_DB=planka
PG_USER=planka
# To generate, run "openssl rand -hex 32" from the terminal. Kept
# hex-only (no base64) since this value is embedded directly in
# DATABASE_URL below - special characters there would need URL-encoding.
PG_PASS=changeme-generate-a-strong-password

# Session encryption key. To generate, run "openssl rand -base64 32".
SECRET_KEY=changeme-generate-a-random-secret

# Set to true if this stack sits behind a reverse proxy.
TRUST_PROXY=false

# Default admin account created on first run - change the password (or
# just log in and change it via the UI) after your first login, then
# these DEFAULT_ vars can be left as-is; they only apply on first setup.
DEFAULT_ADMIN_EMAIL=demo@demo.demo
DEFAULT_ADMIN_USERNAME=demo
DEFAULT_ADMIN_PASSWORD=demo
DEFAULT_ADMIN_NAME=Demo User

# This sets the default language for sending notifications per user (if a user hasn't selected a language) and per board.
DEFAULT_LANGUAGE=en-US
