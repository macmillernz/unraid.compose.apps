# DATA_ROOT is pre-filled by Stacks UI's install wizard based on your
# configured default data root + this stack's name (e.g.
# /mnt/user/appdata/plex) - Plex's own config/database lives here.
DATA_ROOT=/mnt/user/appdata/plex

# Path to your actual media library - update this to match your setup.
MEDIA_ROOT=/mnt/user/data/media

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
