# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/projectsend).
DATA_ROOT=/mnt/user/appdata/projectsend
# Where to store files to share.
DATA_DIR_ROOT=/mnt/user/appdata/projectsend/data

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
