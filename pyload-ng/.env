# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/pyload-ng).
DATA_ROOT=/mnt/user/appdata/pyload-ng
# Destination of pyLoad downloads
DOWNLOADS_ROOT=/mnt/user/appdata/pyload-ng/downloads

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
