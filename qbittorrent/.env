# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/qbittorrent).
DATA_ROOT=/mnt/user/appdata/qbittorrent

# Where finished downloads land.
DOWNLOADS_ROOT=/mnt/user/data/downloads

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
