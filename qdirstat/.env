# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/qdirstat).
DATA_ROOT=/mnt/user/appdata/qdirstat
# Data you want to analyze disk usage information of.
DATA_DIR_ROOT=/mnt/user/appdata/qdirstat/data

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
