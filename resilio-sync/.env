# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/resilio-sync).
DATA_ROOT=/mnt/user/appdata/resilio-sync
# Folder for downloads/cache.
DOWNLOADS_ROOT=/mnt/user/appdata/resilio-sync/downloads
# Sync folders root.
SYNC_ROOT=/mnt/user/appdata/resilio-sync/sync

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
