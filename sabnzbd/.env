# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/sabnzbd).
DATA_ROOT=/mnt/user/appdata/sabnzbd

# Where finished downloads land.
DOWNLOADS_ROOT=/mnt/user/data/downloads/complete

# Work-in-progress downloads.
INCOMPLETE_DOWNLOADS_ROOT=/mnt/user/data/downloads/incomplete

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
