# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/sealskin).
DATA_ROOT=/mnt/user/appdata/sealskin
# All file storage for home directories and ephemeral mounts.
STORAGE_ROOT=/mnt/user/appdata/sealskin/storage
# Docker socket, required to spin up application containers.
VAR_RUN_DOCKER_SOCK_ROOT=/mnt/user/appdata/sealskin/var/run/docker.sock

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# On initial setup this will be used to fill in the default admin configuration file in the `/config` directory, if unset the string HOST_URL will need to be replaced.
HOST_URL=IP or subdomain.doman.com
