# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/sickgear).
DATA_ROOT=/mnt/user/appdata/sickgear
# where you store your tv shows
TV_ROOT=/mnt/user/appdata/sickgear/tv
# your downloads folder for post processing (must not be download in progress)
DOWNLOADS_ROOT=/mnt/user/appdata/sickgear/downloads

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
