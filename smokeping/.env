# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/smokeping).
DATA_ROOT=/mnt/user/appdata/smokeping
# Storage location for db and application data (graphs etc)
DATA_DIR_ROOT=/mnt/user/appdata/smokeping/data

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Specify the master url to connect to. Used when in slave mode.
MASTER_URL=http://<master-host-ip>:80/smokeping/
# Specify the master shared secret for this host. Used when in slave mode.
# To generate, run "openssl rand -base64 32" from the terminal.
SHARED_SECRET=changeme-generate-a-strong-secret
# Specify the cache directory for this host. Used when in slave mode.
CACHE_DIR=/tmp
