# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/speedtest-tracker).
DATA_ROOT=/mnt/user/appdata/speedtest-tracker

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Database hostname (postgres/mysql).
DB_HOST=
# Database port (postgres/mysql).
DB_PORT=
# Database name (postgres/mysql).
DB_DATABASE=
# Database username (postgres/mysql).
DB_USERNAME=
# Database password (postgres/mysql).
# To generate, run "openssl rand -base64 32" from the terminal.
DB_PASSWORD=changeme-generate-a-strong-secret
# Timezone for the UI.
DISPLAY_TIMEZONE=Etc/UTC
# Days to keep test results.
PRUNE_RESULTS_OLDER_THAN=0
