# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/syncthing).
DATA_ROOT=/mnt/user/appdata/syncthing

# The folder(s) you actually want synced - add more volume lines in
# docker-compose.yml (as /data2, /data3, etc.) if you need more than one.
SYNC_ROOT=/mnt/user/data/sync

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
