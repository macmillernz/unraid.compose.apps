# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/syslog-ng).
DATA_ROOT=/mnt/user/appdata/syslog-ng

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# If set to `true` container will log to stdout, otherwise will log to `/config/log/`.
LOG_TO_STDOUT=
