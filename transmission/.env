# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/transmission).
DATA_ROOT=/mnt/user/appdata/transmission

# Where finished downloads land.
DOWNLOADS_ROOT=/mnt/user/data/downloads

# Drop a .torrent file here to have Transmission pick it up automatically.
WATCH_ROOT=/mnt/user/data/downloads/watch

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
