# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/tvheadend).
DATA_ROOT=/mnt/user/appdata/tvheadend
# Where you want the PVR to store recordings.
RECORDINGS_ROOT=/mnt/user/appdata/tvheadend/recordings

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Optionally specify additional arguments to be passed. See Additional runtime parameters.
RUN_OPTS=
