# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/vlc).
DATA_ROOT=/mnt/user/appdata/vlc

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Specify one or multiple VLC CLI flags, this string will be passed to the application in full.
VLC_CLI=--no-qt-minimal-view
