# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/webgrabplus).
DATA_ROOT=/mnt/user/appdata/webgrabplus
# Where webgrabplus should store it's data files.
DATA_DIR_ROOT=/mnt/user/appdata/webgrabplus/data

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC
