# Pre-filled by the install wizard based on your configured default data
# root + this stack's name (e.g. /mnt/user/appdata/wikijs).
DATA_ROOT=/mnt/user/appdata/wikijs
# Where Wiki.js data is stored.
DATA_DIR_ROOT=/mnt/user/appdata/wikijs/data

# Timezone - see https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=UTC

# Set to sqlite (default) or postgres depending on the database engine you wish to use
DB_TYPE=sqlite
# DB hostname (postgres only)
DB_HOST=
# DB port (postgres only)
DB_PORT=
# DB name (postgres only)
DB_NAME=
# DB username (postgres only)
DB_USER=
# DB password (postgres only)
# To generate, run "openssl rand -base64 32" from the terminal.
DB_PASS=changeme-generate-a-strong-secret
